  "name": "Apple Security Vulnerability Report: APFS Logic Bombs",
  "datePublished": "2025-09-30",
  "severity": {
    "cvss": 9.0,
    "rating": "CRITICAL"
  },
  "description": "Three critical vulnerabilities in APFS filesystem handling allow adversaries to create \"logic bombs\" that cause complete system hangs, prevent forensic analysis, and persist across factory resets. The vulnerabilities affect the kernel APFS driver, Time Machine snapshot handling, and extended attribute processing.",
  "vulnerability": {
    "@type": "sec:Vulnerability",
    "severity": "CRITICAL",
    "cvssScore": 9.0
  },
  "impact": {
    "@type": "sec:ImpactAssessment",
    "technicalImpact": "- Complete system hang\n- Process enters uninterruptible disk I/O wait (`U+` state)\n- Cannot be killed with `kill -9`\n- Device may disappear (`/dev/diskX` vanishes)\n- Hard reboot required",
    "scope": "ecosystem-wide",
    "attackComplexity": "high"
  },
